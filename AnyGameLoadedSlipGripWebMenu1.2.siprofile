              },
              "AlwaysExecute": false,
              "ContainerId": "71680d3c-9be0-4fce-bf62-1c9e8499ca3e",
              "AggregationMode": "Corners",
              "Filter": {
                "GammaValue": 1.0,
                "InputGain": 100.0,
                "MinimumForce": 0,
                "Threshold": 0,
                "FilterType": "GammaFilter"
              },
              "Output": {
                "UseHighFrequency": false,
                "HighFrequency": 50,
                "WhiteNoise": 10,
                "UseWhiteNoise": false,
                "FrequencyBasedOnPreFilter": false,
                "UsePrehemptiveMode": false,
                "Frequency": 1,
