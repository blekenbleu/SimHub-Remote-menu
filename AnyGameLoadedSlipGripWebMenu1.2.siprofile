            {
              "ContainerType": "CustomEffectContainer",
              "IsEnabled": true,
              "Gain": 0.0,
              "Description": "Forced Frequency estimated slip/grip with EffectStrength",
              "FrontLeftFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "return $prop('WebMenu.EffectStrength') * 100\r\n\t * $prop('ShakeITBSV3Plugin.Export.ProxyS.FrontLeft')\r\n\t / Math.max(0.1,$prop('ShakeITBSV3Plugin.Export.Grip.FrontLeft'));"
              },
              "FrontRightFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "return $prop('WebMenu.EffectStrength') * 100\r\n  \t * $prop('ShakeITBSV3Plugin.Export.ProxyS.FrontRight')\r\n\t / Math.max(0.1,$prop('ShakeITBSV3Plugin.Export.Grip.FrontRight'));"
              },
              "RearLeftFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "return $prop('WebMenu.EffectStrength') * 100\r\n\t * $prop('ShakeITBSV3Plugin.Export.ProxyS.RearLeft')\r\n\t / Math.max(0.1,$prop('ShakeITBSV3Plugin.Export.Grip.RearLeft'));"
              },
              "RearRightFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "return $prop('WebMenu.EffectStrength') * 100\r\n\t * $prop('ShakeITBSV3Plugin.Export.ProxyS.RearRight')\r\n\t / Math.max(0.1,$prop('ShakeITBSV3Plugin.Export.Grip.RearRight'));"
              },
              "ForceFrequencies": false,
              "FrontLeftFrequencyFormula": {
                "Expression": ""
              },
              "FrontRightFrequencyFormula": {
                "Expression": ""
              },
              "RearLeftFrequencyFormula": {
