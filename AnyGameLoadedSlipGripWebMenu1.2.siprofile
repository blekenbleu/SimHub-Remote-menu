            {
              "ContainerType": "CustomEffectContainer",
              "IsEnabled": true,
              "Gain": 0.0,
              "Description": "ProxyS:  SlipGain, SlipGamma applied to wslip",
              "FrontLeftFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "//return $prop('WebMenu.SlipGain')\r\n//return $prop('WebMenu.SlipGamma');\r\n//return $prop('ShakeITBSV3Plugin.Export.wslip.FrontLeft');\r\nreturn clamp($prop('ShakeITBSV3Plugin.Export.wslip.FrontLeft'),\r\n    $prop('WebMenu.SlipGain'),\r\n    $prop('WebMenu.SlipGamma'));\r\n",
                "PreExpression": "function clamp(slip, gain, gamma) {\r\n\treturn 100 * Math.pow(0.01 * gain * slip, 1 / gamma);\r\n}"
              },
              "FrontRightFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "return clamp($prop('ShakeITBSV3Plugin.Export.wslip.FrontRight'),\r\n    $prop('WebMenu.SlipGain'),\r\n    $prop('WebMenu.SlipGamma'));\r\n",
                "PreExpression": "function clamp(slip, gain, gamma) {\r\n\treturn 100 * Math.pow(0.01 * gain * slip, 1 / gamma);\r\n}"
              },
              "RearLeftFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "return clamp($prop('ShakeITBSV3Plugin.Export.wslip.RearLeft'),\r\n    $prop('WebMenu.SlipGain'),\r\n    $prop('WebMenu.SlipGamma'));\r\n",
                "PreExpression": "function clamp(slip, gain, gamma) {\r\n\treturn 100 * Math.pow(0.01 * gain * slip, 1 / gamma);\r\n}"
              },
              "RearRightFormula": {
                "JSExt": 0,
                "Interpreter": 1,
                "Expression": "return clamp($prop('ShakeITBSV3Plugin.Export.wslip.RearRight'),\r\n    $prop('WebMenu.SlipGain'),\r\n    $prop('WebMenu.SlipGamma'));\r\n",
                "PreExpression": "function clamp(slip, gain, gamma) {\r\n\treturn 100 * Math.pow(0.01 * gain * slip, 1 / gamma);\r\n}"
              },
