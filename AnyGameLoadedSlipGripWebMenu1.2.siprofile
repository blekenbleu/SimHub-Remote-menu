        {
          "ContainerType": "CustomEffectContainer",
          "IsEnabled": true,
          "Gain": 100.0,
          "Description": "output:  thresholded loaded slip/grip",
          "FrontLeftFormula": {
            "JSExt": 0,
            "Interpreter": 1,
            "Expression": "return SlipGate($prop('ShakeITBSV3Plugin.Export.SHslip/grip.FrontLeft'))\r\n\t   * proxyL($prop('AccelerationSway'), $prop('AccelerationSurge'))\r\n\t   - $prop('WebMenu.threshold');",
            "PreExpression": "Sgain = .2;\r\nfunction SlipGate(sg) { return Math.min(1, Sgain * sg) };\r\nfunction AbsAcc(a) { return 100 * Math.pow(Math.abs(.05 * a), 0.3) }\r\n// increasing left load when turning right\r\n// if both sway and surge are 0, then no load shift and each corner gets 25%\r\nfunction proxyL(sway, surge) {\r\n\tvar d = (0 > sway) ? 4 : -4;\r\n\tvar L = 25 + AbsAcc(sway) / d; // 25 +/-25% left-right distribution\r\n\td = (0 < surge) ? 100 : -100;\r\n\treturn L * (1 + AbsAcc(surge) / d); // fore-aft distribution\r\n}"
          },
          "FrontRightFormula": {
            "JSExt": 0,
            "Interpreter": 1,
            "Expression": "return SlipGate($prop('ShakeITBSV3Plugin.Export.SHslip/grip.FrontRight'))\r\n\t   * proxyL($prop('AccelerationSway'), $prop('AccelerationSurge'))\r\n\t   - $prop('WebMenu.threshold');\r\n",
            "PreExpression": "Sgain = .2;\r\nfunction SlipGate(sg) { return Math.min(1, Sgain * sg) };\r\nfunction AbsAcc(a) { return 100 * Math.pow(Math.abs(.05 * a), 0.3) }\r\n// each corner gets 25% for 0 sway and surge\r\nfunction proxyL(sway, surge) {\r\n    var d = (0 < sway) ? 4 : -4;\t// left turns increase load\r\n    var L = 25 + AbsAcc(sway) / d;\t// 25 +/-25% left-right distribution\r\n    d = (0 < surge) ? 100 : -100;\t// braking increases front load\r\n    return L * (1 + AbsAcc(surge) / d); // 0-100% fore-aft distribution\r\n}"
          },
          "RearLeftFormula": {
            "JSExt": 0,
            "Interpreter": 1,
            "Expression": "return SlipGate($prop('ShakeITBSV3Plugin.Export.SHslip/grip.RearLeft'))\r\n\t   * proxyL($prop('AccelerationSway'), $prop('AccelerationSurge'))\r\n\t   - $prop('WebMenu.threshold');",
            "PreExpression": "const Sgain = .2;\r\nfunction SlipGate(sg) { return Math.min(1, Sgain * sg) };\r\nfunction AbsAcc(a) { return 100 * Math.pow(Math.abs(.05 * a), 0.3) }\t// nonlinearity\r\nfunction proxyL(sway, surge) {\r\n    var d = (0 > sway) ? 4 : -4;\t// left load increases for negative sway\r\n    var L = 25 + AbsAcc(sway) / d\t// 25 +/-25% left-right distribution\r\n    d = (0 > surge) ? 100 : -100\t// rear load increases for negative surge\r\n    return L * (1 + AbsAcc(surge) / d); // 0-100% fore-aft distribution\r\n}"
          },
          "RearRightFormula": {
            "JSExt": 0,
            "Interpreter": 1,
            "Expression": "return SlipGate($prop('ShakeITBSV3Plugin.Export.SHslip/grip.RearRight'))\r\n\t   * proxyL($prop('AccelerationSway'), $prop('AccelerationSurge'))\r\n\t   - $prop('WebMenu.threshold');",
            "PreExpression": "const Sgain = .2;\r\nfunction SlipGate(sg) { return Math.min(1, Sgain * sg) };\r\nfunction AbsAcc(a) { return 100 * Math.pow(Math.abs(.05 * a), 0.3); }\r\nfunction proxyL(sway, surge) {\r\n    var d = (0 < sway) ? 4 : -4;\r\n    var L = 25 + AbsAcc(sway) / d  // 0-50% left-right distribution\r\n    d = (0 > surge) ? 100 : -100\r\n    return L * (1 + AbsAcc(surge) / d); // 0-100% fore-aft distribution\r\n}"
          },
          "ForceFrequencies": true,
          "FrontLeftFrequencyFormula": {
            "JSExt": 0,
            "Interpreter": 1,
            "Expression": "return noise(100 - $prop(which));\r\n",
            "PreExpression": "const low = parseInt($prop('WebMenu.Fmin.FrontLeft'));\r\nconst high = parseInt($prop('WebMenu.Fmax.FrontLeft'));\r\nconst f = .01 * (high - low) * 3 / (1 + 3);\t// scale based on 3 and range\r\nfunction noise(sg) { sg = low + f * sg; return sg + Math.random() * sg / 3 };\r\nvar which = (\"AssettoCorsa\" == $prop('DataCorePlugin.CurrentGame'))\r\n\t? 'ShakeITBSV3Plugin.Export.ACslip/grip.FrontLeft'\r\n\t: 'ShakeITBSV3Plugin.Export.SHslip/grip.FrontLeft';"
          },
